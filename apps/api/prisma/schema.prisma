generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  description    String?
  price          Float
  oldPrice       Float?         // Стара ціна (заповнюється автоматично бекендом під час акції)
  stock          Int
  category       String?        
  brand          String?        
  imageUrl       String?
  imageAlt       String?        
  images         ProductImage[]
  ice            Int?           
  sweet          Int?           
  sour           Int?
  specifications ProductSpec[]
  orderItems     OrderItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())
}

model ProductSpec {
  id        String   @id @default(uuid())
  key       String
  value     String
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

enum DiscountType {
  PERCENTAGE // Відсоток (наприклад, 20%)
  FIXED      // Фіксована сума (наприклад, відняти 500 грн)
}

model Promotion {
  id           String       @id @default(uuid())
  name         String       // Назва (наприклад, "Чорна п'ятниця")
  discountType DiscountType 
  value        Float        // Розмір (20 для 20%, або 500 для 500 грн)
  
  // УМОВИ (Таргетинг знижки)
  applyToAll   Boolean      @default(false) // Якщо true - діє на всі товари
  categories   String[]     // Масив категорій ["Laptops", "Phones"]
  productIds   String[]     // Масив ID конкретних товарів
  
  isActive     Boolean      @default(false) // Чи включена знижка зараз
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique              
  name      String?                      
  role      Role     @default(USER)   
  telegramChatId String?   @unique   
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String   
  code      String   
  expiresAt DateTime 
  
  createdAt DateTime @default(now())

  @@index([phone])
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  status            String      @default("PENDING") 
  total             Float       
  deliveryCity      String?
  deliveryWarehouse String?
  items             OrderItem[]
  createdAt         DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     
  price     Float   
}