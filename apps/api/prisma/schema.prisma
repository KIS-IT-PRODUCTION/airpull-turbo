generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String?
  price           Float
  stock           Int
  imageUrl        String?
  images          ProductImage[]
  specifications  ProductSpec[]
  orderItems      OrderItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())
}

model ProductSpec {
  id        String   @id @default(uuid())
  key       String
  value     String
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique             // Номер телефону має бути унікальним
  name      String?                      // Ім'я може бути пустим при реєстрації
  role      Role     @default(USER)      // Роль, щоб потім зробити адмінку
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Перелік ролей
enum Role {
  USER
  ADMIN
}

// Таблиця для зберігання кодів підтвердження (OTP)
model OtpCode {
  id        String   @id @default(uuid())
  phone     String   // Номер, на який відправили код
  code      String   // Сам код (наприклад, "4815")
  expiresAt DateTime // Час, коли код "згорить" (наприклад, через 5 хвилин)
  
  createdAt DateTime @default(now())

  // Індекс для швидкого пошуку по номеру
  @@index([phone])
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  status    String      @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  total     Float       // Загальна сума замовлення
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     // Кількість
  price     Float   // Ціна за 1 шт НА МОМЕНТ ПОКУПКИ (це важливо зберегти!)
}